# ----------------------------------------------------------------------------
# Kovio environment variables
# Copy this file to `.env.local` (gitignored) and fill in real values.
# ----------------------------------------------------------------------------

# Web3Forms — the free form-to-email service used by BOTH the "Get in touch"
# and "Early access" forms. Submitted from the browser (their free plan blocks
# server-side calls). The key is tied to a recipient email in the Web3Forms
# dashboard — set that recipient to koushik@kovio.dev.
# NOTE: file attachments are a Web3Forms Pro feature, so creatives are NOT sent
# via email — they go to Google Drive through the Sheet webhook below.
NEXT_PUBLIC_WEB3FORMS_KEY=

# Google Apps Script Web App URL — the early-access form POSTs each lead here
# (from the browser) to append a row to a Google Sheet AND upload the creative
# to a Google Drive folder, dropping a shareable link in the row.
# The CSV export reads rows back from the same URL.
# See docs/early-access-sheet-setup.md for the script + deploy steps.
NEXT_PUBLIC_SHEETS_WEBHOOK_URL=

# Basic password protecting the internal CSV export at
# /api/leads/export.csv?key=YOUR_PASSWORD
LEADS_EXPORT_PASSWORD=
